# ── Flask server settings ──
# NEVER set FLASK_DEBUG=1 in any publicly reachable deployment.
FLASK_DEBUG=0
PORT=5000
HOST=0.0.0.0

# ── CORS ──
# Comma-separated list of allowed origins for the /predict API.
ALLOWED_ORIGINS=http://localhost:5000

# ── Model artifact paths ──
# Override if you store model files outside the project root.
MODEL_CONFIG_PATH=config.json
MODEL_WEIGHTS_PATH=model_weights.h5
MODEL_LEGACY_PATH=skin_disease_mobilenet.h5

# ── Upload limits ──
MAX_UPLOAD_MB=10
